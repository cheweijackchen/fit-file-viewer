{
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.formatOnPaste": false,
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.formatOnPaste": false,
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
    "editor.formatOnPaste": false,
    "editor.formatOnSave": true
  },
  "[javascript][typescript][typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[scss]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },  
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": false,
  "scssFormatter.singleQuote": true,
  "files.insertFinalNewline": true,
  "cSpell.words": [
    "aeroway",
    "Daba",
    "datatable",
    "dotenvx",
    "Ganzhuowan",
    "Hehuan",
    "hillshade",
    "landcover",
    "landuse",
    "lerp",
    "LTTB",
    "Mabo",
    "mantine",
    "maplibre",
    "maplibregl",
    "maxzoom",
    "minzoom",
    "mlcontour",
    "moveend",
    "Nanheng",
    "Nenggao",
    "Noto",
    "Qilai",
    "scops",
    "tabler",
    "turbopack",
    "Wuling",
